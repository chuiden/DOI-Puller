{
  "manifest_version": 3,

  "name": "DOI Puller",
  "version": "1.0",

  "description": "Extracts gaData.content from JSTOR.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "GA Extractor",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    }
  },

  "commands": {
    "toggle-extractor": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Toggle GA Extractor"
    }
  },

  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  }
}

